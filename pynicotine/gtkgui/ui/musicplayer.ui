<interface>
  <requires lib="gtk+" version="3.0"/>
  <object class="GtkBox" id="container">
    <property name="hexpand">False</property>
    <property name="orientation">vertical</property>
    <property name="visible">True</property>

    <!-- Header -->
    <child>
      <object class="GtkBox" id="header_box">
        <property name="margin-bottom">4</property>
        <property name="margin-end">6</property>
        <property name="margin-start">6</property>
        <property name="margin-top">6</property>
        <property name="spacing">6</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Music Player</property>
            <property name="margin-end">6</property>
            <property name="margin-start">6</property>
            <property name="visible">True</property>
            <property name="hexpand">True</property>
            <property name="xalign">0</property>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="choose_folder_button">
            <property name="icon-name">document-open-symbolic</property>
            <property name="tooltip-text" translatable="yes">Choose folder</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_choose_folder"/>
          </object>
        </child>
      </object>
    </child>

    <!-- File Browser -->
    <child>
      <object class="GtkBox" id="file_browser_box">
        <property name="orientation">vertical</property>
        <property name="vexpand">True</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkScrolledWindow" id="file_list_container">
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="visible">True</property>
            <property name="min-content-width">455</property>
          </object>
        </child>
      </object>
    </child>

    <!-- Separator -->
    <child>
      <object class="GtkSeparator">
        <property name="visible">True</property>
      </object>
    </child>

    <!-- Spectrogram Area -->
    <child>
      <object class="GtkBox" id="spectrogram_box">
        <property name="orientation">vertical</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkDrawingArea" id="spectrogram_area">
            <property name="height-request">150</property>
            <property name="width-request">1</property>
            <property name="hexpand">True</property>
            <property name="visible">True</property>
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="margin-top">4</property>
            <property name="margin-bottom">2</property>
          </object>
        </child>
        <!-- Quality Score Bar -->
        <child>
          <object class="GtkBox" id="_quality_box">
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="margin-top">2</property>
            <property name="spacing">6</property>
            <property name="visible">True</property>
            <child>
              <object class="GtkDrawingArea" id="quality_bar">
                <property name="height-request">12</property>
                <property name="width-request">1</property>
                <property name="hexpand">True</property>
                <property name="valign">center</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="quality_score_label">
                <property name="label"></property>
                <property name="visible">True</property>
                <property name="width-chars">14</property>
                <property name="xalign">1</property>
              </object>
            </child>
            <child>
              <object class="GtkToggleButton" id="cutoff_toggle">
                <property name="icon-name">dialog-warning-symbolic</property>
                <property name="tooltip-text" translatable="yes">Toggle cutoff overlay</property>
                <property name="visible">True</property>
                <property name="active">True</property>
                <property name="valign">center</property>
                <signal name="toggled" handler="on_cutoff_toggled"/>
              </object>
            </child>
          </object>
        </child>
        <!-- Technical Detail -->
        <child>
          <object class="GtkLabel" id="verdict_label">
            <property name="label"></property>
            <property name="margin-start">6</property>
            <property name="margin-end">6</property>
            <property name="margin-bottom">2</property>
            <property name="visible">True</property>
            <property name="wrap">True</property>
            <property name="width-chars">1</property>
            <property name="max-width-chars">50</property>
            <property name="xalign">0</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>

    <!-- Separator -->
    <child>
      <object class="GtkSeparator">
        <property name="visible">True</property>
      </object>
    </child>

    <!-- Now Playing Info -->
    <child>
      <object class="GtkBox" id="now_playing_box">
        <property name="orientation">vertical</property>
        <property name="margin-start">6</property>
        <property name="margin-end">6</property>
        <property name="margin-top">4</property>
        <property name="spacing">2</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkLabel" id="track_title_label">
            <property name="label" translatable="yes">No track loaded</property>
            <property name="ellipsize">end</property>
            <property name="visible">True</property>
            <property name="xalign">0</property>
            <style>
              <class name="heading"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="track_artist_label">
            <property name="label"></property>
            <property name="ellipsize">end</property>
            <property name="visible">True</property>
            <property name="xalign">0</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>

    <!-- Waveform Seek Bar -->
    <child>
      <object class="GtkBox" id="seek_box">
        <property name="margin-start">6</property>
        <property name="margin-end">6</property>
        <property name="spacing">4</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkLabel" id="position_label">
            <property name="label">0:00</property>
            <property name="visible">True</property>
            <property name="width-chars">5</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkDrawingArea" id="waveform_area">
            <property name="height-request">40</property>
            <property name="width-request">1</property>
            <property name="hexpand">True</property>
            <property name="visible">True</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="duration_label">
            <property name="label">0:00</property>
            <property name="visible">True</property>
            <property name="width-chars">5</property>
            <style>
              <class name="dim-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>

    <!-- Player Controls -->
    <child>
      <object class="GtkBox" id="controls_box">
        <property name="halign">center</property>
        <property name="margin-bottom">6</property>
        <property name="margin-top">2</property>
        <property name="spacing">6</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkButton" id="prev_button">
            <property name="icon-name">go-previous-symbolic</property>
            <property name="tooltip-text" translatable="yes">Previous</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_previous"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="play_button">
            <property name="icon-name">media-playback-start-symbolic</property>
            <property name="tooltip-text" translatable="yes">Play</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_play_pause"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="stop_button">
            <property name="icon-name">media-playback-stop-symbolic</property>
            <property name="tooltip-text" translatable="yes">Stop</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_stop"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="next_button">
            <property name="icon-name">go-next-symbolic</property>
            <property name="tooltip-text" translatable="yes">Next</property>
            <property name="visible">True</property>
            <signal name="clicked" handler="on_next"/>
          </object>
        </child>
      </object>
    </child>

    <!-- Volume -->
    <child>
      <object class="GtkBox" id="volume_box">
        <property name="margin-start">6</property>
        <property name="margin-end">6</property>
        <property name="margin-bottom">6</property>
        <property name="spacing">4</property>
        <property name="visible">True</property>
        <child>
          <object class="GtkImage">
            <property name="icon-name">audio-volume-medium-symbolic</property>
            <property name="visible">True</property>
          </object>
        </child>
        <child>
          <object class="GtkScale" id="volume_scale">
            <property name="hexpand">True</property>
            <property name="draw-value">False</property>
            <property name="visible">True</property>
            <property name="adjustment">
              <object class="GtkAdjustment" id="_volume_adjustment">
                <property name="lower">0</property>
                <property name="upper">100</property>
                <property name="value">100</property>
                <property name="step-increment">5</property>
              </object>
            </property>
            <signal name="value-changed" handler="on_volume_changed"/>
          </object>
        </child>
      </object>
    </child>

  </object>
</interface>
